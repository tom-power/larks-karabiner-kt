{
    "title": "larks command control",
    "description": "command to control, for the terminal",
    "rules": [
        {
            "description": "w + left_control (b + left_command)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "b",
                        "modifiers": {
                            "mandatory": [
                                "left_command"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "w",
                            "modifiers": [
                                "left_control"
                            ]
                        }
                    ],
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.jetbrains.*",
                                "^com\\.microsoft\\.VSCode.*",
                                "^com\\.googlecode\\.iterm2$",
                                "^com\\.cmuxterm\\.app$"
                            ]
                        }
                    ]
                }
            ]
        },
