{
    "title": "larks navigation",
    "rules": [
        {
            "description": "Page up (left_control+delete_or_backspace)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "delete_or_backspace",
                        "modifiers": {
                            "mandatory": [
                                "left_control"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "page_up"
                        }
                    ]
                }
            ]
        },
        {
            "description": "Page up (fn+delete_or_backspace)",
            "manipulators": [
                {
                    "type": "basic",
